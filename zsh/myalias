# general shortcuts
alias c='cd '
alias mv='mv -i'
alias rm='rm -i'
alias cp='cp -i'

# listing files — use GNU ls on Mac (gls), regular ls on Linux
if command -v gls &>/dev/null; then
    alias ls="gls --color"
elif ls --color=auto / &>/dev/null 2>&1; then
    alias ls="ls --color=auto"
fi
command -v vivid &>/dev/null && export LS_COLORS="$(vivid generate catppuccin-mocha)"

# git
alias gs="git status"
alias gb="git branch -vv"
alias gp="git pull --rebase"

# tmux
alias tm="tmux"
alias tmls="tmux ls"
alias tmat="tmux a -t"
alias tmkill="tmux kill-session -t"

# editing shortcuts
alias m='vim'
alias n='nvim'
alias mf='m $(fzf)'
alias nf='n $(fzf)'

# make python3 default
alias python='python3'
alias pip='pip3'

# cd into a dir by using fzf
alias cdf='cd $(find . -type d -print | fzf)'
